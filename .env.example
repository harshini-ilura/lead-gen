# Database / queue
DATABASE_URL=postgresql+asyncpg://leadgen:leadgen@db:5432/leadgen
SYNC_DATABASE_URL=postgresql+psycopg2://leadgen:leadgen@db:5432/leadgen
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Google Maps Platform (Places API New)
GOOGLE_MAPS_API_KEY=

# Dubai Pulse / DLD (register at dubaipulse.gov.ae for free OAuth credentials)
DUBAI_PULSE_API_KEY=
DUBAI_PULSE_API_SECRET=
DUBAI_PULSE_TOKEN_URL=https://api.dubaipulse.gov.ae/oauth/client_credential/accesstoken
DUBAI_PULSE_API_URL=https://api.dubaipulse.gov.ae

# OSM Overpass
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter

# Crawling / reliability
CRAWL_USER_AGENT=LagentryBot/1.0 (+https://lagentry.example/bot)
CRAWL_MAX_PAGES_PER_DOMAIN=40
CRAWL_DELAY_MIN_SECONDS=5
CRAWL_DELAY_MAX_SECONDS=15
RECRAWL_DAYS=45
CRAWL_MAX_RETRIES=2

# Email verification (paid verifier — disabled by default)
PAID_VERIFY_ENABLED=false
MILLIONVERIFIER_API_KEY=
BOUNCER_API_KEY=
PAID_VERIFY_MONTHLY_CAP=2000
PAID_VERIFY_PROVIDER=millionverifier

# Outreach
OUTREACH_WEBHOOK_URL=

# Target
TARGET_COUNTRY=AE
TARGET_NICHE=real_estate_agency
